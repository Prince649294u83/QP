# ---- APPLICATION ----
APP_NAME=DSATM Question Paper Generator
APP_ENV=development
DEBUG=True
SECRET_KEY=generate-a-random-256-bit-hex-string-here
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- DATABASE ----
# The app can run locally with SQLite for quick frontend development.
# For production use PostgreSQL and run Alembic migrations.
DATABASE_URL=sqlite:///./qpgen.db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=dsatm_user
POSTGRES_PASSWORD=dsatm_password
POSTGRES_DB=dsatm_qpgen
POSTGRES_DATABASE_URL=postgresql+asyncpg://dsatm_user:dsatm_password@localhost:5432/dsatm_qpgen

# ---- MONGODB / CHROMADB ----
MONGODB_URL=mongodb://localhost:27017
MONGO_DB=dsatm_docs
CHROMA_PERSIST_PATH=./data/chromadb

# ---- FILE STORAGE ----
STORAGE_ROOT=./storage
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=50

# ---- OLLAMA (LOCAL - NO API KEY) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=phi4-mini
OLLAMA_VISION_MODEL=llava
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_MAX_RETRIES=3

# ---- EMBEDDINGS / LOCAL FORMATTER ----
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cuda
FLAN_T5_ADAPTER_PATH=./data/flan_t5_adapter
FLAN_T5_BASE_MODEL=google/flan-t5-large
FLAN_T5_USE_8BIT=True

# ---- SMTP (GMAIL APP PASSWORD - NO API KEY) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USER=your-dsatm-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM_NAME=DSATM QP Generator

# ---- DEV SEED ----
ALLOW_DEMO_SEED=true
